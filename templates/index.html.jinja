<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex,nofollow">
    <meta name="googlebot" content="noindex">
    <title>SmartFastAPI — REST API Template</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
          crossorigin="anonymous">
    <link href="/static/css/main.css" rel="stylesheet">
</head>
<body>

<div class="main-container">
    <!-- Banner Card -->
    <div class="banner-card">
        <h1 class="banner-title">SmartFastAPI</h1>
        
        <p class="banner-desc">
            <strong>SmartFastAPI</strong> is a production-ready RESTful template using <strong>FastAPI</strong>, <strong>SQLAlchemy</strong> and <strong>Jinja2</strong>.
        </p>
        <p class="banner-desc">
            It fully supports OpenAPI specifications. Start building REST APIs quickly with sensible defaults and examples.
        </p>

        <!-- Action Buttons -->
        <div class="action-row">
            <a href="/docs" class="btn-custom btn-blue">Explore APIs</a>
            
            <a href="/redoc" class="btn-custom btn-grey-outline">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-code" viewBox="0 0 16 16" style="margin-inline-end: 2px;">
                    <path d="M5.854 4.854a.5.5 0 1 0-.708-.708l-3.5 3.5a.5.5 0 0 0 0 .708l3.5 3.5a.5.5 0 0 0 .708-.708L2.707 8l3.147-3.146zm4.292 0a.5.5 0 1 1 .708-.708l3.5 3.5a.5.5 0 0 1 0 .708l-3.5 3.5a.5.5 0 0 1-.708-.708L13.293 8l-3.147-3.146z"/>
                </svg>
                ReDoc
            </a>
            
            <a href="/api/persons/" class="btn-custom btn-grey-outline">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-people" viewBox="0 0 16 16">
                    <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1h8Zm-7.978-1A.261.261 0 0 1 7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002a.274.274 0 0 1-.014.002H7.022ZM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0ZM6.936 9.28a5.88 5.88 0 0 0-1.23-.247A7.35 7.35 0 0 0 5 9c-4 0-5 3-5 4 0 .667.333 1 1 1h4.216A2.238 2.238 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816ZM6 2a2 2 0 1 1-3.998-.002A2 2 0 0 1 6 2Zm-.76 5.188A2.69 2.69 0 0 1 3 7c-1.2 0-2.067.444-2.597.93C.168 8.175 0 8.5 0 9c0 .229.076.398.2.5.12.099.281.146.438.146H5c0-.289.042-.57.12-.843A2.929 2.929 0 0 1 5.24 7.188Z"/>
                </svg>
                Persons API
            </a>

            <a href="/api/users/" class="btn-custom btn-grey-outline">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-person" viewBox="0 0 16 16">
                    <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0Zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4Zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10Z"/>
                </svg>
                Users API
            </a>
            
            <a href="/openapi.json" download="openapi.json" class="btn-custom btn-green-outline">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-download" viewBox="0 0 16 16">
                    <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                    <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"/>
                </svg>
                Download OpenAPI
            </a>
        </div>

        <!-- Meta info -->
        <div class="version-info">
            Profile: <strong>default</strong> &middot; Version: <strong>{{version}}</strong>
        </div>
    </div>

    <!-- Cards Grid -->
    <div class="card-grid">
        <!-- Card 1 -->
        <div class="info-card">
            <div class="card-header-row">
                <span class="card-icon icon-blue">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-gear-fill" viewBox="0 0 16 16">
                        <path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872l-.1-.34zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z"/>
                    </svg>
                </span>
                Ready-to-use APIs
            </div>
            <p class="card-text">
                REST endpoints with examples and automated documentation via OpenAPI / Swagger UI.
            </p>
        </div>

        <!-- Card 2 -->
        <div class="info-card">
            <div class="card-header-row">
                <span class="card-icon icon-green">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-database-fill" viewBox="0 0 16 16">
                        <path d="M3.904 13.733C3.902 13.86 3.9 13.97 3.9 14c0 .412.76 1 3.1 1s3.1-.588 3.1-1c0-.03-.002-.14-.004-.267C9.284 14.414 8.7 14.5 8 14.5c-.7 0-1.284-.086-2.096-.767zm7.986-3.045C11.284 11.414 10.7 11.5 8 11.5c-.7 0-1.284-.086-2.096-.767C5.902 10.86 5.9 10.97 5.9 11c0 .412.76 1 3.1 1s3.1-.588 3.1-1c0-.03-.002-.14-.004-.267zM8 9c-.7 0-1.284-.086-2.096-.767C5.902 8.36 5.9 8.47 5.9 8.5c0 .412.76 1 3.1 1s3.1-.588 3.1-1c0-.03-.002-.14-.004-.267C9.284 8.914 8.7 9 8 9zm5-5.75c0 .412-.76 1-3.1 1s-3.1-.588-3.1-1c0-.03.002-.14.004-.267C6.716 3.086 7.3 3 8 3c.7 0 1.284.086 2.096.767C9.902 3.64 9.9 3.75 9.9 3.75z"/>
                        <path d="M8 1c-2.757 0-5 1.007-5 2.25v2.5C3 6.993 5.243 8 8 8s5-1.007 5-2.25v-2.5C13 2.007 10.757 1 8 1zm0 9c-2.757 0-5 1.007-5 2.25v2.5C3 14.993 5.243 16 8 16s5-1.007 5-2.25v-2.5C13 12.007 10.757 11 8 11zm0-4c-2.757 0-5 1.007-5 2.25v2.5C3 10.993 5.243 12 8 12s5-1.007 5-2.25v-2.5C13 8.007 10.757 7 8 7z"/>
                    </svg>
                </span>
                Persistence
            </div>
            <p class="card-text">
                SQLAlchemy and SQLite with database seeding and sessions for rapid development.
            </p>
        </div>

        <!-- Card 3 -->
        <div class="info-card">
            <div class="card-header-row">
                <span class="card-icon icon-yellow">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-shield-fill-check" viewBox="0 0 16 16">
                        <path d="M8 0c-.69 0-1.843.265-2.928.56-1.11.3-2.229.655-2.887.87a1.54 1.54 0 0 0-1.044 1.262c-.596 4.477.787 7.795 2.465 9.99a11.775 11.775 0 0 0 2.517 2.453c.386.273.744.482 1.048.625.28.132.581.24.829.24s.548-.108.829-.24a7.159 7.159 0 0 0 1.048-.625 11.775 11.775 0 0 0 2.517-2.453c1.678-2.195 3.061-5.513 2.465-9.99a1.54 1.54 0 0 0-1.044-1.263 62.439 62.439 0 0 0-2.887-.87C9.843.266 8.69 0 8 0zm2.146 5.146a.5.5 0 0 1 .708.708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 7.793l2.646-2.647z"/>
                    </svg>
                </span>
                Production-friendly
            </div>
            <p class="card-text">
                Standard Uvicorn server, clean dependency structure, and sensible defaults for deployment.
            </p>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
        crossorigin="anonymous"></script>
</body>
</html>
